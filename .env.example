# ═══════════════════════════════════════════════════════════════════════
#  USKill Engine API — environment variables
#  Copy to .env and fill in values.  Never commit .env to source control.
# ═══════════════════════════════════════════════════════════════════════

# ── Application ─────────────────────────────────────────────────────
APP_ENV=development            # development | production | test
APP_VERSION=2.0.0
# REQUIRED in production: must be ≥32 chars and not the default value
APP_SECRET_KEY=dev-secret-change-me-in-production-min-32-chars

# ── Database (PostgreSQL + pgvector) ────────────────────────────────
DATABASE_URL=postgresql+asyncpg://uskill:uskill@localhost:5432/uskill
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_CONNECT_RETRIES=10        # startup retry attempts
DATABASE_CONNECT_RETRY_DELAY=2.0   # seconds between retries (doubles each attempt)

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Rate limits (requests / minute per plan) ─────────────────────────
RATE_LIMIT_FREE=10
RATE_LIMIT_PRO=120
RATE_LIMIT_ENTERPRISE=2000

# ── Skill / connection limits per plan ───────────────────────────────
MAX_EPISODES_FREE=500
MAX_EPISODES_PRO=10000
MAX_EPISODES_ENTERPRISE=100000

MAX_CONNECTIONS_FREE=3
MAX_CONNECTIONS_PRO=25
MAX_CONNECTIONS_ENTERPRISE=0       # 0 = unlimited

MAX_BATCH_SIZE_FREE=5
MAX_BATCH_SIZE_PRO=20
MAX_BATCH_SIZE_ENTERPRISE=50

# ── Rollback ──────────────────────────────────────────────────────────
ROLLBACK_TTL_HOURS=72

# ── Jobs ──────────────────────────────────────────────────────────────
JOB_RETENTION_DAYS=7
ASYNC_THRESHOLD_EPISODES=2000

# ── Webhooks ──────────────────────────────────────────────────────────
# REQUIRED in production: must be ≥20 chars and not the default value
WEBHOOK_SECRET=dev-webhook-secret-change-in-production
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_MAX_RETRIES=3
WEBHOOK_OUTBOX_MAX_ATTEMPTS=5     # max delivery attempts before marking 'failed'

# ── Input sanitisation ────────────────────────────────────────────────
TASK_MAX_BYTES=8000               # hard byte cap on task/name free-text fields
TASK_ALLOW_HTML=false             # reject HTML tags in free-text inputs

# ── CORS ──────────────────────────────────────────────────────────────
# REQUIRED in production: set to explicit origins, not '*'
# CORS_ORIGINS=https://app.mycompany.com,https://admin.mycompany.com
CORS_ORIGINS=*

# ── Scoring defaults ──────────────────────────────────────────────────
DEFAULT_GAP_THRESHOLD=0.70
DEFAULT_BLEND_BASE=true

# ── OpenTelemetry (optional) ──────────────────────────────────────────
OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4317   # OTLP gRPC collector endpoint
OTEL_SERVICE_NAME=uskill-api
